{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "Launch by NTT DATA — design tokens",
  "version": "1.0.0",
  "description": "Canonical brand tokens. Source of truth for all Launch artifacts — workshops, decks, signal. Other consumers derive from this file.",
  "color": {
    "accent": {
      "blue":       { "value": "#1E5AF2", "comment": "Launch Blue — primary CTA, highlights on dark mode" },
      "blue-dim":   { "value": "#1749CC", "comment": "Blue hover / pressed state" },
      "blue-light": { "value": "#E8EFFE", "comment": "Blue tint — backgrounds, fills" },
      "lavender":   { "value": "#CED4FE", "comment": "Supporting accent, light blue tone" },
      "yellow":     { "value": "#FFCC2D", "comment": "Launch Yellow — highlights on light mode, strong accents" },
      "yellow-dim": { "value": "#E6B800", "comment": "Yellow hover / pressed state" },
      "beige":      { "value": "#FFEFE3", "comment": "Soft highlights on light mode (= N5)" },
      "red":        { "value": "#FF1C52", "comment": "Corrective / warning only" },
      "coral":      { "value": "#FECED9", "comment": "Soft red tone, supporting" }
    },
    "neutral": {
      "n1": { "value": "#111113", "comment": "Dark mode background (primary)" },
      "n2": { "value": "#252424", "comment": "Dark mode background (secondary)" },
      "n3": { "value": "#77706F", "comment": "Muted / supporting text" },
      "n4": { "value": "#908A89", "comment": "Lighter muted text" },
      "n5": { "value": "#FFEFE3", "comment": "Light mode background / card (= Beige)" },
      "n6": { "value": "#FCF8F5", "comment": "Light mode background (primary)" },
      "n7": { "value": "#FFFFFF", "comment": "White — pure light mode or cards" },
      "border":      { "value": "#E8E3DF", "comment": "Light mode hairline border" },
      "border-dark": { "value": "#333130", "comment": "Dark mode hairline border" }
    }
  },
  "font": {
    "family": {
      "print": { "value": "Avenir Next LT Pro", "comment": "PPTX / print only — licensed, embedded in template. Use Demi weight for bold." },
      "web":   { "value": "Outfit", "comment": "Canonical web typeface (Slidev, workshops, signal)" },
      "web-stack": { "value": "'Outfit', 'Avenir Next LT Pro', 'Avenir Next', 'Inter', system-ui, -apple-system, sans-serif" },
      "mono":  { "value": "'DM Mono', 'JetBrains Mono', 'SF Mono', Menlo, monospace" }
    },
    "scale": {
      "stat":    { "size": "64px", "weight": "600", "comment": "Hero stat / big number (print 64pt)" },
      "hero":    { "size": "44px", "weight": "600", "lineHeight": "1.1", "comment": "Cover / big statement" },
      "title":   { "size": "32px", "weight": "600", "lineHeight": "1.2", "comment": "Slide / page title" },
      "section": { "size": "24px", "weight": "600", "lineHeight": "1.3", "comment": "Section header" },
      "body":    { "size": "16px", "weight": "400", "lineHeight": "1.6" },
      "eyebrow": { "size": "13px", "weight": "600", "lineHeight": "1.4", "letterSpacing": "0.12em", "transform": "uppercase" },
      "small":   { "size": "12px", "weight": "400", "lineHeight": "1.4" },
      "caption": { "size": "10px", "weight": "400", "lineHeight": "1.4" }
    }
  },
  "radius": {
    "sm":   { "value": "5px",  "comment": "Tags, badges, small chips" },
    "md":   { "value": "7px",  "comment": "Buttons, inputs" },
    "lg":   { "value": "12px", "comment": "Cards, stat tiles" },
    "xl":   { "value": "16px", "comment": "Shells, panels" }
  },
  "border": {
    "hairline": { "value": "0.5px", "comment": "Standard card / panel border weight" }
  },
  "stripe": {
    "value": "3px",
    "comment": "Left accent stripe on cards — yellow=workshop, blue=deck, red=corrective"
  }
}
